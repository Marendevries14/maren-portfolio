@namespace MVDesign.Components.Sections
@using MVDesign.Components.UI

<section id="over" class="bg-paper py-28">
    <Container>
        <div class="grid gap-16 lg:grid-cols-[0.9fr_1.1fr]">
            <div class="rounded-[3rem] bg-sage/80 p-10 text-white soft-shadow">
                <h2 class="text-5xl">Altijd in beweging.</h2>
                <div class="mt-6 h-1 w-24 bg-accent"></div>

                <p class="mt-8 max-w-md leading-8 text-white/85">
                    Nieuwe plekken, nieuwe perspectieven. Ik haal energie uit ontdekken,
                    leren en dingen creëren die blijven.
                </p>

                <div class="mt-10 grid grid-cols-2 gap-4">
                    <div class="rounded-2xl bg-white/20 p-5">Reizen</div>
                    <div class="rounded-2xl bg-white/20 p-5">Tuinieren</div>
                    <div class="rounded-2xl bg-white/20 p-5">Geluidstechniek</div>
                    <div class="rounded-2xl bg-white/20 p-5">Paardenhouderij</div>
                </div>
            </div>

            <div class="flex flex-col justify-center">
                <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                    Over mij
                </p>

                <h2 class="mt-5 max-w-3xl text-6xl leading-tight text-cocoa">
                    Verbindende schakel tussen techniek & operatie.
                </h2>

                <p class="mt-8 max-w-2xl text-lg leading-8 text-cocoa/75">
                    Ik voel me thuis op het snijvlak van IT, operatie en creativiteit.
                    Structuur aanbrengen, mensen verbinden en slimme ideeën omzetten
                    naar praktische oplossingen — dát is waar ik blij van word.
                </p>

                <p class="mt-5 max-w-2xl text-lg leading-8 text-cocoa/75">
                    Onder druk blijf ik rustig, ik schakel snel en denk in mogelijkheden.
                    Met oog voor detail én het grotere geheel.
                </p>

                <p class="script mt-10 text-4xl text-primary">
                    Maren ♡
                </p>
            </div>
        </div>
    </Container>
</section>