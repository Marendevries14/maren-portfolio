@namespace MVDesign.Components.Sections
@using MVDesign.Components.UI

<style>
    .tech-label {
        display: inline-block;
        padding: 0.25rem 0.75rem;
        background-color: #f5f1e8;
        border: 1px solid #e8e0d5;
        border-radius: 0.25rem;
        font-size: 0.75rem;
        font-weight: 600;
        color: #6b4e3d;
        margin-right: 0.5rem;
        margin-bottom: 0.5rem;
    }
</style>

<section class="paper relative min-h-screen overflow-hidden pt-36">
    <div class="absolute left-[45%] top-32 hidden h-40 w-40 rounded-full bg-sage/30 lg:block"></div>
    <div class="absolute right-16 bottom-20 h-52 w-52 rounded-full bg-primary/20"></div>

    <Container>
        <div class="grid min-h-[82vh] items-center gap-16 lg:grid-cols-[0.95fr_1.05fr]">
            <div class="relative z-10">
                <p class="mb-8 text-sm font-bold uppercase tracking-[0.22em] text-sage">
                    Techniek. Creativiteit. Impact.
                </p>

                <h1 class="max-w-4xl text-6xl leading-[0.95] text-cocoa md:text-8xl">
                    Ik bouw digitale ervaringen
                    <span class="script block pt-2 text-5xl text-primary md:text-7xl">
                        Samen.
                    </span>
                </h1>

                <div class="mt-8 h-1 w-28 rounded-full bg-accent"></div>

                <p class="mt-10 max-w-xl text-lg leading-8 text-cocoa/75">
                    Van idee tot werkende oplossing. Ik combineer softwareontwikkeling,
                    UX en projectstructuur om systemen te bouwen die écht werken in de praktijk.
                </p>

                <div class="mt-10 flex flex-wrap gap-4">
                    <a href="#projecten" class="rounded-full bg-primary px-8 py-4 font-semibold text-white soft-shadow transition hover:-translate-y-1">
                        Bekijk mijn werk →
                    </a>

                    <a href="#over" class="rounded-full border border-cocoa/20 px-8 py-4 font-semibold text-cocoa transition hover:bg-white/60">
                        Meer over mij
                    </a>
                </div>

                <div class="mt-14">
                    <p class="mb-5 text-xs font-bold uppercase tracking-[0.25em] text-cocoa/50">
                        Gebouwd op nieuwsgierigheid
                    </p>

                    <div class="flex flex-wrap">
                        <span class="tech-label">🦋 Creatieve maker</span>
                        <span class="tech-label">📍 Reisliefhebber</span>
                        <span class="tech-label">⌘ Tech enthousiast</span>
                        <span class="tech-label">🐴 Buitenmens</span>
                        <span class="tech-label">▥ Geluid & systemen</span>
                    </div>
                </div>
            </div>

            <div class="relative">
                <div class="absolute left-0 top-10 h-[520px] w-[520px] organic bg-sage/35"></div>
                <div class="absolute right-0 bottom-4 h-56 w-56 rounded-full bg-primary/30"></div>

                <div class="absolute right-10 top-4 z-20 h-12 w-36 tape"></div>

                <div class="relative z-10 mx-auto max-w-xl">
                    <div class="organic overflow-hidden soft-shadow">
                        <img src="images/maren-hero.jpg"
                             alt="Portret van Maren de Vries"
                             class="h-[680px] w-full object-cover object-center" />
                    </div>

                    @* <div class="absolute -bottom-10 left-16 rotate-[-4deg] bg-paper p-6 soft-shadow">
                        <p class="script text-lg text-cocoa">
                            Oplossingen<br />
                            die werken.<br />
                            Voor mensen.<br />
                            In de praktijk.
                        </p>
                    </div> *@

                    <div class="absolute -right-6 bottom-8 text-7xl">
                        🦋
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>