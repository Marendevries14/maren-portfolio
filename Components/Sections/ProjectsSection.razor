@namespace MVDesign.Components.Sections
@using MVDesign.Components.UI

<section id="projecten" class="bg-paper py-28">
    <Container>
        <div class="max-w-3xl">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                Projecten & ervaring
            </p>

            <h2 class="mt-5 text-6xl leading-tight text-cocoa">
                Werk dat techniek en mensen dichter bij elkaar brengt.
            </h2>
        </div>

        <div class="mt-16 grid gap-8 lg:grid-cols-2">
            <article class="overflow-hidden rounded-[2.5rem] bg-cream soft-shadow">
                <div class="h-72 bg-sage/60"></div>
                <div class="p-10">
                    <p class="text-sm font-bold uppercase tracking-[0.22em] text-primary">Arriva</p>
                    <h3 class="mt-4 text-4xl text-cocoa">Product Owner dashboardproject</h3>
                    <p class="mt-5 leading-8 text-cocoa/70">
                        Wensen uit de operatie vertalen naar technische requirements,
                        testplannen opstellen, testen met gebruikers en afstemmen met developers.
                    </p>
                </div>
            </article>

            <article class="overflow-hidden rounded-[2.5rem] bg-cream soft-shadow">
                <div class="h-72 bg-blue/50"></div>
                <div class="p-10">
                    <p class="text-sm font-bold uppercase tracking-[0.22em] text-primary">TRES</p>
                    <h3 class="mt-4 text-4xl text-cocoa">AI proof of concept & toegankelijkheid</h3>
                    <p class="mt-5 leading-8 text-cocoa/70">
                        End-to-end afstudeerproject met onderzoek naar WCAG,
                        website-analyse en ontwikkeling met JavaScript, Vue en .NET.
                    </p>
                </div>
            </article>
        </div>
    </Container>
</section>