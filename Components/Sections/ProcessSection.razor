@using MVDesign.Components.UI
@using MVDesign.Components.Shared

<section id="process" class="bg-secondary py-28">
    <Container>
        <SectionHeader
            Eyebrow="Proces"
            Title="Van ruwe idee tot verfijnde ervaring."
            Description="Een eenvoudige workflow die merk, interface en code op elkaar afstemt." />

        <div class="mt-16 grid gap-6 md:grid-cols-4">
            @foreach (var step in Steps)
            {
                <div class="rounded-[2rem] border border-white/10 bg-white/[0.04] p-8">
                    <span class="text-sm text-accent">@step.Number</span>
                    <h3 class="mt-6 text-xl font-bold text-white">@step.Title</h3>
                    <p class="mt-4 text-sm leading-relaxed text-slate-400">@step.Text</p>
                </div>
            }
        </div>
    </Container>
</section>

@code {
    private readonly List<Step> Steps =
    [
        new("01", "Positionering", "Bepaal de boodschap, doelgroep en digitale persoonlijkheid."),
        new("02", "Design", "Creëer het visuele systeem, het lay-outritme en de interactiestijl."),
        new("03", "Bouwen", "Ontwikkel herbruikbare .NET-componenten met TailwindCSS."),
        new("04", "Lanceren", "Optimaliseer prestaties, SEO, toegankelijkheid en deployment.")
    ];

    private record Step(string Number, string Title, string Text);
}