@namespace MVDesign.Components.Sections
@using MVDesign.Components.UI

<section id="expertise" class="bg-cream py-28">
    <Container>
        <div class="max-w-3xl">
            <p class="text-sm font-bold uppercase tracking-[0.25em] text-primary">
                Expertise
            </p>

            <h2 class="mt-5 text-6xl leading-tight text-cocoa">
                Creatief denken, technisch bouwen, praktisch organiseren.
            </h2>
        </div>

        <div class="mt-16 grid gap-8 md:grid-cols-3">
            <article class="rounded-[2.5rem] bg-paper p-8 soft-shadow">
                <span class="text-4xl">⌘</span>
                <h3 class="mt-8 text-3xl text-cocoa">Software & UX</h3>
                <p class="mt-4 leading-7 text-cocoa/70">
                    Ervaring met .NET, Vue, JavaScript, digitale toegankelijkheid en het vertalen
                    van gebruikersbehoeften naar werkende oplossingen.
                </p>
            </article>

            <article class="rounded-[2.5rem] bg-paper p-8 soft-shadow">
                <span class="text-4xl">▦</span>
                <h3 class="mt-8 text-3xl text-cocoa">Projectstructuur</h3>
                <p class="mt-4 leading-7 text-cocoa/70">
                    Planning, backlog, Scrum, Agile en het creëren van overzicht binnen teams,
                    processen en technische projecten.
                </p>
            </article>

            <article class="rounded-[2.5rem] bg-paper p-8 soft-shadow">
                <span class="text-4xl">⚡</span>
                <h3 class="mt-8 text-3xl text-cocoa">Operatie & techniek</h3>
                <p class="mt-4 leading-7 text-cocoa/70">
                    Snel schakelen, analyseren en besluiten onder druk. Altijd met aandacht
                    voor wat in de praktijk écht werkt.
                </p>
            </article>
        </div>
    </Container>
</section>