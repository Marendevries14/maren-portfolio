@using MVDesign.Components.UI

<section id="contact" class="relative overflow-hidden bg-slate-950 py-28">
    <div class="absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/20 blur-3xl"></div>

    <Container>
        <div class="relative z-10 rounded-[2.5rem] border border-white/10 bg-white/[0.04] p-10 text-center backdrop-blur md:p-20">
            <p class="text-sm uppercase tracking-[0.3em] text-accent">Start met bouwen</p>

            <h2 class="mx-auto mt-6 max-w-4xl text-5xl font-black leading-tight text-white md:text-7xl">
                Klaar om je merk te transformeren naar een premium digitale ervaring?
            </h2>

            <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
                Laten we een website maken die doelgericht, snel, memorabel en klaar voor groei is.
            </p>

            <div class="mt-10">
                <Button Text="Start een project" Href="mailto:hello@mvdesign.dev" />
            </div>
        </div>
    </Container>
</section>